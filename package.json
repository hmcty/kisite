{
  "name": "kisite",
  "version": "1.0.1",
  "type": "module",
  "description": "Static site generator for KiCad projects",
  "license": "GPL-3.0-only",
  "bin": {
    "kisite": "bin/kisite.js"
  },
  "keywords": [
    "kicad",
    "kicanvas",
    "pcb",
    "vite"
  ],
  "files": [
    "bin/",
    "src/",
    "lib/",
    "index.html",
    "tsconfig.json"
  ],
  "scripts": {
    "check-kicanvas": "test -e ./vendor/kicanvas/.git || exit 1",
    "build-kicanvas": "cd ./vendor/kicanvas && npm install && npm run build",
    "copy-kicanvas": "mkdir -p lib && cp ./vendor/kicanvas/build/kicanvas.js lib/",
    "prepublish": "npm run check-kicanvas && npm run build-kicanvas && npm run copy-kicanvas",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/dompurify": "^3.0.5",
    "@types/marked": "^5.0.2",
    "@types/node": "^20.12.7",
    "prettier": "3.8.1",
    "typescript": "^5.4.5",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "dompurify": "^3.3.3",
    "marked": "^17.0.6",
    "marked-base-url": "^1.1.8",
    "tsx": "^4.7.2",
    "vite": "^8.0.7"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hmcty/kisite.git"
  }
}
